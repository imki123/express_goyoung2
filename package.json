{
  "name": "express_goyoung2",
  "version": "1.0.0",
  "description": "express backend",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon --exec ts-node src/app.ts",
    "build": "tsc -p .",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "eslint": "eslint --fix src tests --ext .ts --ignore-pattern dist",
    "prettier": "prettier --write src tests package.json \".env copy\" jest.config.cjs tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "check:all": "pnpm eslint && pnpm prettier && pnpm typecheck && pnpm test"
  },
  "author": "goyoung2",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
